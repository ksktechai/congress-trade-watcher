        <mxCell id="pg" value="PostgreSQL 16&#10;(Flyway-managed)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1080" y="720" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- App container -->
        <mxCell id="app" value="congress-trade-watcher (Quarkus)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#999999;dashed=1;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="150" y="70" width="840" height="780" as="geometry" />
        </mxCell>

        <!-- Scheduler -->
        <mxCell id="scheduler" value="IngestionScheduler&#10;@Scheduled (cron) — OFF in dev/test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="170" y="110" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- REST API -->
        <mxCell id="api" value="REST API (JAX-RS)&#10;Trade / Member / Signal / Digest / Admin&#10;+ ApiAccessLoggingFilter (req/resp logs)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
