{
  "info": {
    "_postman_id": "208293fb-64b1-4daa-a4d5-eed40ec89e1c",
    "name": "congress-trade-watcher",
    "description": "Congress Trade Watcher API. Research tool, NOT financial advice. Set the {{baseUrl}} collection variable to point at your environment (default http://localhost:8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "4991288"
  },
  "item": [
    {
      "name": "get-all-trades",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/trades",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "trades"]
        }
      },
      "response": []
    },
    {
      "name": "get-all-trades-by",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/trades?member=Donald J Trump&type=PURCHASE",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "trades"],
          "query": [
            { "key": "member", "value": "Donald J Trump" },
            { "key": "type", "value": "PURCHASE" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "trade-by-ticker",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/trades?ticker=AAPL",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "trades"],
          "query": [
            { "key": "ticker", "value": "AAPL" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "trades-by-date-range",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Filter trades by transaction date (ISO yyyy-MM-dd). from/to are inclusive.",
        "url": {
          "raw": "{{baseUrl}}/api/v1/trades?from=2026-01-01&to=2026-06-30",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "trades"],
          "query": [
            { "key": "from", "value": "2026-01-01" },
            { "key": "to", "value": "2026-06-30" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "get-all-congress-members",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/members",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "members"]
        }
      },
      "response": []
    },
    {
      "name": "get-congress-member-trades",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Exact full name (URL-encoded). Use a name from get-all-congress-members.",
        "url": {
          "raw": "{{baseUrl}}/api/v1/members/Donald J Trump/trades",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "members", "Donald J Trump", "trades"]
        }
      },
      "response": []
    },
    {
      "name": "get-signals",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/signals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "signals"]
        }
      },
      "response": []
    },
    {
      "name": "get-signals-by",
      "request": {
        "method": "GET",
        "header": [],
        "description": "type = CLUSTER | OUTLIER | LATE_DISCLOSURE | SECTOR_CONCENTRATION",
        "url": {
          "raw": "{{baseUrl}}/api/v1/signals?ticker=GOOGL&type=OUTLIER",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "signals"],
          "query": [
            { "key": "ticker", "value": "GOOGL" },
            { "key": "type", "value": "OUTLIER" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "re-run-signals-detect",
      "request": {
        "method": "POST",
        "header": [],
        "description": "Re-run pure-code signal detection over the look-back window and persist the results.",
        "url": {
          "raw": "{{baseUrl}}/api/v1/signals/detect",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "signals", "detect"]
        }
      },
      "response": []
    },
    {
      "name": "daily-digest",
      "request": {
        "method": "GET",
        "header": [],
        "description": "LLM-narrated daily digest. ?refresh=true bypasses the per-day cache and forces a fresh LLM call.",
        "url": {
          "raw": "{{baseUrl}}/api/v1/digest/daily?refresh=true",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "digest", "daily"],
          "query": [
            { "key": "refresh", "value": "true" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "ingest-data",
      "request": {
        "method": "POST",
        "header": [],
        "description": "Ingest the whole watchlist from the default free source (congress.kadoa.com).",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/ingest",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "ingest"]
        }
      },
      "response": []
    },
    {
      "name": "ingest-single-ticker",
      "request": {
        "method": "POST",
        "header": [],
        "description": "Ingest just one symbol from the default free source.",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/ingest?ticker=AAPL",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "ingest"],
          "query": [
            { "key": "ticker", "value": "AAPL" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "ingest-via-finnhub",
      "request": {
        "method": "POST",
        "header": [],
        "description": "Ingest via Finnhub instead of the default congress source. Requires a paid FINNHUB_API_KEY (the congressional endpoint is premium; a free key returns 403).",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/ingest?source=finnhub",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "ingest"],
          "query": [
            { "key": "source", "value": "finnhub" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "health-readiness",
      "request": {
        "method": "GET",
        "header": [],
        "description": "SmallRye health readiness (includes a DB check).",
        "url": {
          "raw": "{{baseUrl}}/q/health/ready",
          "host": ["{{baseUrl}}"],
          "path": ["q", "health", "ready"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
