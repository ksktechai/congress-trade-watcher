# =========================================================================
# Congress Trade Watcher — environment variables
#
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# The application reads these as environment variables; no secret is ever
# stored in application.properties.
#
#   cp .env.example .env
#   # then either `export $(grep -v '^#' .env | xargs)` or use direnv / your IDE
# =========================================================================

# --- Trade data source ---------------------------------------------------
# Default source is the FREE Congress Trading Monitor open dataset
# (congress.kadoa.com) — needs NO key. Override with INGESTION_SOURCE=finnhub
# to use Finnhub instead (its congressional endpoint needs a PAID plan).
# INGESTION_SOURCE=congress

# Finnhub key — only needed if INGESTION_SOURCE=finnhub (or ?source=finnhub).
# Free signup: https://finnhub.io/  (NOTE: congressional-trading is premium; a
# free key returns HTTP 403. The /quote endpoint is free.)
# FINNHUB_API_KEY=your-finnhub-api-key-here

# --- LLM narration provider ----------------------------------------------
# Which provider narrates the daily digest: "gemini" (default), "openrouter",
# or "anthropic". Set the matching key below for whichever you choose.
LLM_PROVIDER=gemini

# Google Gemini API (free tier). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter (free models available). Get a key: https://openrouter.ai/keys
# Used when LLM_PROVIDER=openrouter. Default model is openrouter/free.
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic Claude API (alternative; pay-as-you-go).
# Get a key: https://console.anthropic.com/  (Settings -> API Keys)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Optional: database (defaults match docker-compose.yml) --------------
POSTGRES_PASSWORD=congress_secret
# POSTGRES_USER=congress_app
# POSTGRES_DB=congress
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Optional: pgAdmin (only when started with --profile tools) ----------
# PGADMIN_PASSWORD=admin
